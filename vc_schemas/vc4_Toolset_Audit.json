{
  "@context": [
    "https://www.w3.org/ns/credentials/v2",
    "https://schema.org"
  ],
  "type": ["VerifiableCredential", "AgentToolsetCredential"],
  "name": "Agent Toolset Certification",
  "description": "Certifies that the tools integrated by the Agent are authentic, operational, and correctly authorized.",
  "credentialSubject": {
    "id": "will_be_replaced_by_code",
    "auditId": "AUDIT-2025-12-15-001",
    "toolManifest": [
      {
        "@type": "SoftwareApplication",
        "name": "SHA-256 Calculator",
        "identifier": "tool.hash.sha256",
        "providerProtocol": "native",
        "serverId": "local-holder-runtime",
        "serverEndpoint": "local://holder-runtime",
        "description": "Calculates the SHA-256 hash of a given text string for verification purposes.",
        "allowedActions": [
          "execute"
        ],
        "allowedResources": [
          "urn:dagg:holder:probe*"
        ],
        "permissions": "local-compute",
        "rateLimit": "Unlimited",
        "riskLevel": "low",
        "operationalStatus": "active"
      },
      {
        "@type": "SoftwareApplication",
        "name": "Web Search via MCP",
        "identifier": "tool.web.search",
        "providerProtocol": "mcp",
        "serverId": "demo-search",
        "serverEndpoint": "http://localhost:9300/mcp",
        "description": "Queries external web search results through an MCP Server.",
        "allowedActions": [
          "query"
        ],
        "allowedResources": [
          "resource:web.search:*"
        ],
        "permissions": "external-read",
        "rateLimit": "60/min",
        "riskLevel": "medium",
        "operationalStatus": "active"
      }
    ]
  }
}
