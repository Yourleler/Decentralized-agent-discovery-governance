{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dagg.local/schemas/vp-format.schema.json",
  "title": "Agent VP Format",
  "description": "VP format compatible with infrastructure/wallet.py and infrastructure/validator.py.",
  "type": "object",
  "required": [
    "@context",
    "type",
    "holder",
    "verifiableCredential",
    "proof"
  ],
  "properties": {
    "@context": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "id": {
      "type": "string"
    },
    "type": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "contains": {
        "const": "VerifiablePresentation"
      }
    },
    "holder": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "id"
          ],
          "properties": {
            "id": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "holderBinding": {
      "type": "object",
      "properties": {
        "agentDid": {
          "type": "string"
        },
        "adminAddress": {
          "type": "string"
        },
        "opAddress": {
          "type": "string"
        },
        "opKid": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "verifiableCredential": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "proof": {
      "type": "object",
      "required": [
        "type",
        "created",
        "verificationMethod",
        "proofPurpose",
        "challenge",
        "jws"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "verificationMethod": {
          "type": "string"
        },
        "proofPurpose": {
          "type": "string"
        },
        "challenge": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "jws": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "session": {
      "type": "object",
      "properties": {
        "requestId": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "verifierDid": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
