{
  "version": "2.0.0",
  "metadata_schema": "config/agent_metadata_format.schema.json",
  "embedding": {
    "provider": "sentence-transformers",
    "model_name": "sentence-transformers/all-mpnet-base-v2",
    "normalize_embeddings": true
  },
  "vector_store": {
    "backend": "chromadb",
    "collection_name": "agent_metadata_v2",
    "distance_metric": "cosine"
  },
  "document_id_rule": {
    "agent_pattern": "{agentDid}",
    "capability_pattern": "{agentDid}:{capability.id_or_name}"
  },
  "vector_fields": {
    "global": [
      "service.name",
      "service.summary",
      "service.domain",
      "service.tags",
      "indexHints.searchableKeywords"
    ],
    "per_capability": [
      "capabilities[].name",
      "capabilities[].description",
      "capabilities[].inputs",
      "capabilities[].outputs",
      "capabilities[].examples"
    ]
  },
  "vector_text_template": {
    "global_format": "{service.summary}\nDomain: {service.domain}\nTags: {service.tags}\nKeywords: {indexHints.searchableKeywords}",
    "per_capability_format": "Capability: {capability.name}\nDescription: {capability.description}\nInputs: {capability.inputs}\nOutputs: {capability.outputs}\nExamples: {capability.examples}",
    "joiner": "\n---\n"
  },
  "retrieval": {
    "top_k": 20,
    "return_limit": 10,
    "similarity_threshold": 0.1,
    "deduplicate_by": "agentDid"
  }
}
