{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dagg.local/schemas/agent-metadata-format.schema.json",
  "title": "Agent Metadata",
  "description": "Minimal metadata payload stored by metadata CID.",
  "type": "object",
  "required": [
    "metadataVersion",
    "agentDid",
    "service",
    "capabilities",
    "vcManifest",
    "timestamps"
  ],
  "properties": {
    "metadataVersion": {
      "type": "string",
      "default": "2.0.0"
    },
    "agentDid": {
      "type": "string",
      "pattern": "^did:"
    },
    "adminAddress": {
      "type": "string"
    },
    "service": {
      "type": "object",
      "required": [
        "name",
        "summary",
        "domain"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "interactionModes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "endpoint": {
          "type": "string"
        },
        "serviceEndpoint": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "url"
          ],
          "additionalProperties": true
        },
        "endpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "protocol": {
                "type": "string"
              },
              "auth": {
                "type": "string"
              }
            },
            "required": [
              "url"
            ],
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "vcManifest": {
      "type": "object",
      "required": [
        "holderDid",
        "types",
        "lazyFetch"
      ],
      "properties": {
        "holderDid": {
          "type": "string",
          "pattern": "^did:"
        },
        "types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "lazyFetch": {
          "type": "boolean",
          "default": true
        },
        "fullVcRefs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "cid": {
                "type": "string"
              },
              "uri": {
                "type": "string"
              },
              "hash": {
                "type": "string"
              }
            },
            "required": [
              "type"
            ],
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "indexHints": {
      "type": "object",
      "properties": {
        "vectorText": {
          "type": "string"
        },
        "searchableKeywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "timestamps": {
      "type": "object",
      "required": [
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
