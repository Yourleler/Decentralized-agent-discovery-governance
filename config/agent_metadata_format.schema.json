{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dagg.local/schemas/agent-metadata-format.schema.json",
  "title": "Agent Service Metadata (CID Payload)",
  "description": "链上 metadataCid 指向的元数据格式。用于 Sidecar 拉取与向量化。",
  "type": "object",
  "required": [
    "metadataVersion",
    "agentDid",
    "service",
    "capabilities",
    "vcManifest",
    "indexHints",
    "timestamps"
  ],
  "properties": {
    "metadataVersion": {
      "type": "string",
      "default": "1.0.0"
    },
    "agentDid": {
      "type": "string",
      "description": "必须与链上 registerAgent 的 did 一致。"
    },
    "adminAddress": {
      "type": "string",
      "description": "可选冗余字段，便于展示与追责。"
    },
    "opBinding": {
      "type": "object",
      "description": "可选。OP 池与 DID delegate 绑定信息（摘要）。",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "defaultKid": {
          "type": "string"
        },
        "opPool": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "kid": {
                "type": "string"
              },
              "address": {
                "type": "string"
              }
            },
            "required": [
              "kid",
              "address"
            ],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": true
    },
    "service": {
      "type": "object",
      "required": [
        "name",
        "summary",
        "domain",
        "interactionModes",
        "endpoints"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "description": "1~3 句自然语言概述，向量检索主要输入之一。"
        },
        "domain": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "interactionModes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "endpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "protocol": {
                "type": "string"
              },
              "auth": {
                "type": "string"
              },
              "sla": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "url",
              "protocol"
            ],
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "capabilities": {
      "type": "array",
      "description": "用于语义匹配的核心内容。",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "vcManifest": {
      "type": "object",
      "required": [
        "holderDid",
        "types",
        "lazyFetch"
      ],
      "properties": {
        "holderDid": {
          "type": "string"
        },
        "types": {
          "type": "array",
          "description": "如 AgentIdentityCredential, AgentModelCredential...",
          "items": {
            "type": "string"
          }
        },
        "lazyFetch": {
          "type": "boolean",
          "description": "是否按需拉取 Full VC，与你设计文档一致应为 true。"
        },
        "fullVcRefs": {
          "type": "array",
          "description": "可选：每类 VC 对应的 CID 或 URI。",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "cid": {
                "type": "string"
              },
              "hash": {
                "type": "string"
              },
              "size": {
                "type": "integer"
              }
            },
            "required": [
              "type"
            ],
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "trustHints": {
      "type": "object",
      "description": "可选：Sidecar 排序阶段的轻量提示，不替代链上真值。",
      "properties": {
        "minClientScore": {
          "type": "number"
        },
        "region": {
          "type": "string"
        },
        "supportedJurisdictions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "indexHints": {
      "type": "object",
      "required": [
        "vectorText"
      ],
      "properties": {
        "vectorText": {
          "type": "string",
          "description": "Sidecar 直接向量化文本，建议拼接 service+capabilities。"
        },
        "searchableKeywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "timestamps": {
      "type": "object",
      "required": [
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "integrity": {
      "type": "object",
      "description": "可选：内容完整性校验摘要。",
      "properties": {
        "metadataSha256": {
          "type": "string"
        },
        "schemaVersion": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

