{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dagg.local/schemas/vc-format.schema.json",
  "title": "Agent VC Format",
  "description": "Lightweight VC envelope compatible with existing vc_schemas and runtime validator.",
  "type": "object",
  "required": [
    "@context",
    "type",
    "issuer",
    "credentialSubject",
    "proof"
  ],
  "allOf": [
    {
      "anyOf": [
        {
          "required": [
            "issuanceDate"
          ]
        },
        {
          "required": [
            "validFrom"
          ]
        }
      ]
    }
  ],
  "properties": {
    "@context": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "id": {
      "type": "string"
    },
    "type": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "contains": {
        "const": "VerifiableCredential"
      }
    },
    "issuer": {
      "type": "string"
    },
    "issuanceDate": {
      "type": "string",
      "format": "date-time"
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "credentialSubject": {
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "agentDid": {
          "type": "string"
        },
        "claimsVersion": {
          "type": "string",
          "default": "1.0.0"
        }
      },
      "additionalProperties": true
    },
    "credentialStatus": {
      "type": "object"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "cid": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          }
        },
        "required": [
          "type"
        ],
        "additionalProperties": true
      }
    },
    "proof": {
      "type": "object",
      "required": [
        "type",
        "created",
        "verificationMethod",
        "proofPurpose",
        "jws"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "verificationMethod": {
          "type": "string"
        },
        "proofPurpose": {
          "type": "string"
        },
        "jws": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
